# A.D.A — Variables de entorno (copiar a .env y ajustar)
# Modo: production (generar ingresos) o development (pruebas). Ver docs/PRODUCCION.md
# ADA_ENV=production
#
# Solo 4 servicios arrancan por defecto (postgres, ada_core, memory_service, chat_interface).
# No definas COMPOSE_PROFILES si quieres solo esos; si la defines (ej. telegram), arrancarán también los servicios de ese perfil.
# COMPOSE_PROFILES=

PG_USER=ada_user
PG_PASSWORD=supersecret
PG_DB=ada_main
PG_PORT=5432

# Ollama (F4): nativo en el host (Mac mini / Mac). No hay contenedor Ollama.
# ADA v2 Minimal Core: default llama3:8b, fallback qwen2:7b (configurable).
# OLLAMA_MODEL=llama3:8b
# OLLAMA_FALLBACK_MODEL=qwen2:7b
# OLLAMA_VISION_MODEL: para que ADA interprete imágenes en local (ej. llava). Sin esto, con imagen se usa Gemini si GEMINI_API_KEY está definido.
# OLLAMA_VISION_MODEL=llava
# OLLAMA_URL: en Mac con Docker, por defecto http://host.docker.internal:11434/api/generate. Solo definir si Ollama está en otra máquina/puerto.
#
# Herramientas tipo Cursor/Claude (agent-core): LIST_DIR y GREP siempre activas. Para que ADA ejecute comandos (npm, python, etc.):
# ADA_ALLOW_RUN_COMMAND=true
# ADA_RUN_COMMAND_ALLOWLIST=npm,node,python,ls,cat,grep,find,git,curl  (opcional; por defecto hay lista segura)
# ADA_RUN_COMMAND_TIMEOUT=60
# Recursos (Ollama nativo; opcional en ada_resources.env):
# OLLAMA_NUM_THREADS=4
# En agent-core: contexto y longitud de respuesta (menos tokens = más rápido)
# OLLAMA_NUM_CTX=4096
# OLLAMA_NUM_PREDICT=1024

# Correo de A.D.A (para registro en plataformas: Gumroad, Etsy, etc.)
# La contraseña NUNCA debe ir en código; solo en .env (y .env no se sube a git)
ADA_EMAIL=ada@tudominio.com
ADA_EMAIL_PASSWORD=

# Webmail para revisar el correo de ADA (cPanel; puerto 2096)
# Login: quita /webmaillogout.cgi o usa la raíz del host
ADA_EMAIL_WEBMAIL_URL=https://s422.nyc7.mysecurecloudhost.com:2096/

# IMAP para registro asistido (abrir enlace de verificación desde el script signup-helper)
# Host del servidor de correo (ej. s422.nyc7.mysecurecloudhost.com)
# ADA_IMAP_HOST=
# ADA_IMAP_PORT=993
# ADA_IMAP_USE_SSL=true

# Autonomía: true = ADA ejecuta compras aprobadas por política sin pedir aprobación humana (ver docs/AUTONOMIA-ADA.md)
# ADA_AUTONOMOUS_PURCHASES=false

# Telegram: bot (chat-bridge) y envío de mensajes. Para que ADA te avise por Telegram cuando necesite ayuda, define TELEGRAM_CHAT_ID (agent-core lo usa para notificar).
# CHAT_BRIDGE_URL suele ser http://chat-bridge:8081 (por defecto en compose). Si no usas Docker, pon la URL donde corre el chat-bridge.
# Token del bot (crear con @BotFather). Obligatorio para el bot y para enviar mensajes.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Chat ID del usuario o grupo al que enviar mensajes (ej. tu número +573228610411: esa persona debe abrir el bot y enviar /start; luego obtén el chat_id con: ./chat-bridge/scripts/telegram_send_once.sh)
# TELEGRAM_CHAT_ID=123456789
